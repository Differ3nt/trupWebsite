    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-react": "^5.0.4",
    "@xmldom/xmldom": "^0.9.10",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "gaxios": "^7.1.4",
    "google-auth-library": "^10.6.2",
    "gpxparser": "^3.0.8",
