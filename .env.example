# PostgreSQL connection string (e.g. postgresql://user:pass@host:5432/trup)
DATABASE_URL=

# NextAuth v5: a random 32+ char secret. Generate with `openssl rand -base64 32`.
AUTH_SECRET=

# Public base URL of the deployed app (e.g. https://trup.example.com)
AUTH_URL=http://localhost:3000

# Google OAuth credentials — get from Google Cloud Console.
# NextAuth v5 auto-discovers the AUTH_GOOGLE_* names; no extra wiring needed.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email of the permanent owner account (cannot be demoted/deleted)
OWNER_EMAIL=

# Web Push (optional — push notifications disabled if any are missing)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
