// Schema reconciliation status (see REBUILD_PLAN.md §8 / §9):
//
// Reconciled with server/index.ts runMigrations():
//   - Event.imageFocalX/Y, Event.plannedDistance/Elevation/Duration added.
//   - onDelete: Cascade added to EventParticipation, GpxSubmission, Notification,
//     PushSubscription relations (§9) so deleting a user/event is one operation
//     instead of the manual multi-step cascade in legacy users.ts. NOTE: this
//     changes FK definitions vs. the existing prod DB — the Phase 0 baseline
//     migration (run against a prod clone once DB access lands) will emit the
//     ALTER for these FKs. The schema now expresses the intended final state.
//
// Suspect drift, pending `prisma db pull` against a prod clone to confirm:
//   - Event.actualDuration: in schema, NOT in runMigrations() — likely added via `prisma db push`.
//   - WikiArticle.tags, WikiArticle.authorName: in schema, NOT in CREATE TABLE in runMigrations().
//   - GpxSubmission.order, mapLink, mapEmbed, status: in schema, no CREATE TABLE for GpxSubmission
//     in runMigrations() at all (assumed to predate that mechanism).
//   - Notification: schema relation has no explicit onDelete; runMigrations() CREATE TABLE sets
//     FK ON DELETE CASCADE. Drift between schema and DB until the relation is annotated.
// These are deferred to Phase 0 schema baseline.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(uuid())
  email             String               @unique
  googleId          String?              @unique
  name              String?
  nickname          String?
  avatarUrl         String?
  role              Role                 @default(USER)
  status            UserStatus           @default(ACTIVE)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  hardware          String[]             @default([])
  phoneNumber       String?
  lastLogoutAt      DateTime?
  participations    EventParticipation[]
  gpxSubmissions    GpxSubmission[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
}

model Event {
  id                String               @id
  title             String
  dateStart         DateTime
  dateEnd           DateTime?
  type              String
  mapLink           String?
  gearRequired      String[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  description       String?
  image             String?
  location          String?
  featured          Boolean              @default(false)
  difficulty        Int?
  spots             Int?
  highlighted       Boolean              @default(false)
  isExpedition      Boolean              @default(false)
  gearCritical      String[]             @default([])
  mapEmbed          String?
  isDraft           Boolean              @default(false)
  isFinalized       Boolean              @default(false)
  organizer         String?
  meetingPointName  String?
  meetingPointLink  String?
  meetingPointEmbed String?
  transport         String?
  weatherInfo       String?
  actualDistance    Float?
  actualElevation   Float?
  actualDuration    Float?
  imageFocalX       Float?               @default(50)
  imageFocalY       Float?               @default(50)
  plannedDistance   Float?
  plannedElevation  Float?
  plannedDuration   Float?
  participants      EventParticipation[]
  gpxSubmissions    GpxSubmission[]
}

model EventParticipation {
  id               String   @id @default(uuid())
  userId           String
  eventId          String
  status           String
  createdAt        DateTime @default(now())
  notifyDaysBefore Int?
  attended         Boolean  @default(false)
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Album {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  distance    Float?
  duration    Float?
  locationMap String?
  description String?
  createdAt   DateTime @default(now())
  location    String?
  images      Image[]
}

model Image {
  id           String   @id @default(uuid())
  albumId      String?
  originalUrl  String
  thumbnailUrl String?
  uploadedById String?
  createdAt    DateTime @default(now())
  height       Int?
  size         Int?
  width        Int?
  name         String?
  album        Album?   @relation(fields: [albumId], references: [id])
  tags         Tag[]    @relation("ImageTags")
}

model Tag {
  id     String  @id @default(uuid())
  name   String  @unique
  images Image[] @relation("ImageTags")
}

model GpxSubmission {
  id             String    @id @default(uuid())
  userId         String
  eventId        String
  filePath       String
  distance       Float
  duration       Float
  elevationGain  Float?
  participantIds String[]  @default([])
  isOfficial     Boolean   @default(false)
  label          String?
  mapLink        String?
  mapEmbed       String?
  status         GpxStatus @default(PENDING)
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  event          Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("SYSTEM")
  url       String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WikiArticle {
  id         String   @id @default(uuid())
  title      String
  content    String
  category   String
  tags       String[] @default([])
  authorId   String?
  authorName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model NewsItem {
  id        String   @id
  title     String
  content   String?
  type      String   @default("GENERAL")
  imageUrl  String?
  link      String?
  eventId   String?
  articleId String?
  priority  Int?     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  FLAGGED
}

enum GpxStatus {
  PENDING
  APPROVED
  REJECTED
}
